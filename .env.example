# Copy to .env and fill in. compose.yml loads this file (env_file).
# Only variables the app actually reads are listed here.

# --- Required ---
# Rails secret key base decryptor. Get it with: cat config/master.key
RAILS_MASTER_KEY=

# --- App ---
# Public hostname, used for URLs in emails (and host authorization if you enable it).
APP_HOST=bookshelf.example.com
# Run background jobs (EPUB processing) inside Puma. Unset if you run a dedicated
# jobs container instead (see compose.example.yml).
SOLID_QUEUE_IN_PUMA=1

# --- Email (optional) ---
# Leave SMTP_ADDRESS blank to disable outgoing mail entirely.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USER_NAME=
SMTP_PASSWORD=
SMTP_DOMAIN=

# --- Tuning (optional) ---
# Puma worker processes (defaults to 1 if unset).
WEB_CONCURRENCY=
# Threads per worker; also sets the SQLite connection pool size.
RAILS_MAX_THREADS=5
