<div class="grid grid-cols-5 gap-8">
    <% authors.each do |author| %>
        <% first_book = author.books.first %>
        <div class="relative group">
            <%= link_to author_show_path(author), class: "block h-full", data: { turbo_frame: "_top" } do %>
                <article class="h-full flex flex-col overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm hover:shadow-md transition-shadow">
                    <div class="aspect-[2.8/4] w-full relative overflow-hidden bg-gray-100 flex-shrink-0">
                        <% if first_book&.cover? %>
                            <%= book_cover(first_book, class: "object-cover w-full h-full absolute scale-110 blur") %>
                            <%= book_cover(first_book, class: "object-contain w-full h-full absolute") %>
                        <% else %>
                            <div class="absolute inset-0 flex items-center justify-center text-gray-400">
                                <div class="text-center p-4">
                                    <svg class="w-12 h-12 mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                                    </svg>
                                    <p class="text-xs"><%= t("common.no_cover") %></p>
                                </div>
                            </div>
                        <% end %>
                    </div>

                    <div class="p-4 flex-1 flex flex-col justify-between min-h-[100px]">
                        <h3 class="font-semibold text-gray-900 text-sm mb-3 line-clamp-3 leading-tight">
                            <%= author.name %>
                        </h3>

                        <div class="text-xs text-gray-500 mt-auto">
                            <%= t("common.book_count", count: author.books.count) %>
                        </div>
                    </div>
                </article>
            <% end %>

            <!-- Merge button - appears on hover -->
            <%= link_to merge_author_path(author),
                class: "absolute top-2 right-2 bg-blue-600 text-white p-2 rounded-full shadow-lg opacity-0 group-hover:opacity-100 transition-opacity hover:bg-blue-700 z-10",
                title: t(".merge_title"),
                data: { turbo_frame: "_top" } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                </svg>
            <% end %>
        </div>
    <% end %>
</div>
