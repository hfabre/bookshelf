<div class="max-w-4xl mx-auto">
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Merge Author</h1>
        <p class="mt-1 text-sm text-gray-600">
          Merge similar authors into: <span class="font-semibold"><%= @author.name %></span>
        </p>
      </div>
      <%= link_to "← Back to Authors", authors_path, class: "text-blue-600 hover:text-blue-800" %>
    </div>
  </div>

  <% if @similar_authors.any? %>
    <%= form_with url: perform_merge_author_path(@author), method: :post, local: true, class: "space-y-6", data: { controller: "author-merge-form" } do |form| %>
      <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Similar Authors Found</h2>
          <p class="mt-1 text-sm text-gray-600">
            Select the authors you want to merge into <span class="font-semibold"><%= @author.name %></span>
          </p>
        </div>

        <div class="p-6">
          <div class="space-y-4">
            <% @similar_authors.each do |similar_author| %>
              <div class="flex items-center p-4 border border-gray-200 rounded-lg hover:bg-gray-50">
                <input type="checkbox"
                       name="author_ids[]"
                       value="<%= similar_author.id %>"
                       id="author_<%= similar_author.id %>"
                       class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded"
                       data-author-merge-form-target="checkbox"
                       data-action="change->author-merge-form#toggleSelection">

                <label for="author_<%= similar_author.id %>" class="ml-4 flex-1 cursor-pointer">
                  <div class="flex items-center justify-between">
                    <div>
                      <div class="font-medium text-gray-900"><%= similar_author.name %></div>
                      <div class="text-sm text-gray-500">
                        <%= pluralize(similar_author.books.count, 'book') %>
                        <% if similar_author.books.any? %>
                          - <%= similar_author.books.limit(3).pluck(:title).join(", ") %>
                          <% if similar_author.books.count > 3 %>
                            and <%= similar_author.books.count - 3 %> more...
                          <% end %>
                        <% end %>
                      </div>
                    </div>

                    <% if similar_author.respond_to?(:similarity_score) %>
                      <div class="text-xs text-gray-400">
                        Match: <%= number_to_percentage(similar_author.similarity_score, precision: 0) %>
                      </div>
                    <% end %>
                  </div>
                </label>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-between">
        <div class="text-sm text-gray-500">
          <span data-author-merge-form-target="selectedCount">0</span> author(s) selected for merging
        </div>

        <div class="flex space-x-3">
          <%= link_to "Cancel", authors_path, class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50" %>
          <%= form.submit "Merge Selected Authors",
                          class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed",
                          data: { author_merge_form_target: "submitButton" },
                          disabled: true %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="bg-white shadow rounded-lg p-8 text-center">
      <div class="text-gray-400 mb-4">
        <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 12h6m-6-4h6m2 5.291A7.962 7.962 0 0112 15c-2.34 0-4.47-.881-6.08-2.33"></path>
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No Similar Authors Found</h3>
      <p class="text-gray-600 mb-6">
        We couldn't find any authors similar to "<%= @author.name %>" in your library.
      </p>
      <%= link_to "Back to Authors", authors_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700" %>
    </div>
  <% end %>
</div>
