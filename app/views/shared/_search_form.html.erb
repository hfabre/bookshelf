<div class="bg-white sm:rounded-sm">
    <div class="px-4 py-5 sm:p-6">
        <%= form_with url: path, method: :get, local: true,
            data: {
            controller: "search",
            action: "turbo:submit-start->search#showLoading turbo:submit-end->search#hideLoading",
            turbo_frame: local_assigns[:turbo_frame] || "books"
            },
            class: "space-y-4" do |form| %>

        <div>
            <%= form.text_field :q,
                value: params[:q],
                placeholder: local_assigns[:placeholder] || t(".default_placeholder"),
                autocomplete: "off",
                class: "form-input",
                data: {
                search_target: "input",
                action: "input->search#search"
                } %>
        </div>

        <% if local_assigns[:extra_fields].present? %>
            <%= render local_assigns[:extra_fields] %>
        <% end %>

        <div class="hidden" data-search-target="loading">
            <div class="text-sm text-gray-500">
                <span><%= t(".searching") %></span>
            </div>
        </div>
        <% end %>
    </div>
</div>
