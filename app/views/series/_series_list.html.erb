<div class="grid grid-cols-5 gap-8">
    <% series.each do |serie| %>
        <% first_book = serie.books.first %>
        <%= link_to serie_show_path(serie), class: "block h-full", data: { turbo_frame: "_top" } do %>
            <article class="h-full flex flex-col overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm hover:shadow-md transition-shadow">
                <div class="aspect-[2.8/4] w-full relative overflow-hidden bg-gray-100 flex-shrink-0">
                    <% if first_book&.cover? %>
                        <%= book_cover(first_book, class: "object-cover w-full h-full absolute scale-110 blur") %>
                        <%= book_cover(first_book, class: "object-contain w-full h-full absolute") %>
                    <% else %>
                        <div class="absolute inset-0 flex items-center justify-center text-gray-400">
                            <div class="text-center p-4">
                                <svg class="w-12 h-12 mx-auto mb-2" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                                </svg>
                                <p class="text-xs">No cover</p>
                            </div>
                        </div>
                    <% end %>
                </div>

                <div class="p-4 flex-1 flex flex-col justify-between min-h-[120px]">
                    <div>
                        <h3 class="font-semibold text-gray-900 text-sm mb-3 line-clamp-3 leading-tight">
                            <%= serie.name %>
                        </h3>

                        <% if serie.rating.present? %>
                            <div class="flex items-center mb-2">
                                <% serie.rating.times do %>
                                    <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                <% end %>
                                <% (5 - serie.rating).times do %>
                                    <svg class="w-4 h-4 text-gray-300 fill-current" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                <% end %>
                                <span class="ml-2 text-sm font-medium text-gray-700"><%= serie.rating %>/5</span>
                            </div>
                        <% else %>
                            <div class="mb-2 text-sm text-gray-400 h-6">No rating</div>
                        <% end %>
                    </div>

                    <div class="text-xs text-gray-500 mt-auto">
                        <%= pluralize(serie.books.count, 'book') %>
                    </div>
                </div>
            </article>
        <% end %>
    <% end %>
</div>
