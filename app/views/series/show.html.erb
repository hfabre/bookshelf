<div class="max-w-7xl mx-auto">
  <div class="mb-8">
    <%= link_to series_back_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Series
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-8">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @serie.name %></h1>

          <div class="flex items-center space-x-4 mb-6">
            <p class="text-lg text-gray-600">
              <%= pluralize(@books.count, 'book') %> in this series
            </p>

            <% if @serie.rating.present? %>
              <div class="flex items-center">
                <span class="text-sm text-gray-500 mr-2">Rating:</span>
                <% @serie.rating.times do %>
                  <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                <% end %>
                <% (5 - @serie.rating).times do %>
                  <svg class="w-4 h-4 text-gray-300 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                <% end %>
                <span class="ml-2 text-sm text-gray-600">(<%= @serie.rating %>/5)</span>
              </div>
            <% end %>
          </div>

          <% if @serie.completion_state.present? || @serie.reading_state.present? %>
            <div class="mb-4 space-y-2">
              <% if @serie.completion_state.present? %>
                <div class="flex items-center">
                  <svg class="w-4 h-4 text-gray-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span class="text-sm text-gray-600 mr-2">Series Status:</span>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                    <%= case @serie.completion_state
                        when 'completed' then 'bg-green-100 text-green-800'
                        when 'ongoing' then 'bg-blue-100 text-blue-800'
                        when 'cancelled' then 'bg-red-100 text-red-800'
                        else 'bg-gray-100 text-gray-800'
                        end %>">
                    <%= @serie.completion_state.humanize %>
                  </span>
                </div>
              <% end %>

              <% if @serie.reading_state.present? %>
                <div class="flex items-center">
                  <svg class="w-4 h-4 text-gray-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                  </svg>
                  <span class="text-sm text-gray-600 mr-2">Reading Status:</span>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                    <%= case @serie.reading_state
                        when 'finished' then 'bg-green-100 text-green-800'
                        when 'reading' then 'bg-yellow-100 text-yellow-800'
                        when 'unread' then 'bg-gray-100 text-gray-800'
                        else 'bg-gray-100 text-gray-800'
                        end %>">
                    <%= @serie.reading_state.humanize %>
                  </span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="flex items-center space-x-3">
          <% unless browsing_other_library? %>
            <%= link_to edit_series_path(@serie),
                class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Edit Series
            <% end %>
          <% end %>

          <% if @books.any? %>
            <%= link_to download_series_path(@serie),
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Download All Books
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <h2 class="text-xl font-semibold text-gray-900 mb-6">Books in <%= @serie.name %></h2>

    <% if @books.any? %>
      <div class="grid grid-cols-5 gap-8">
        <% @books.each do |book| %>
          <article class="overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm relative">
            <% if book.serie_index.present? %>
              <div class="absolute top-2 left-2 bg-indigo-600 text-white text-xs font-bold px-2 py-1 rounded z-10">
                #<%= book.serie_index %>
              </div>
            <% end %>
            <%= render "books/book_modal", book: book %>
            <%= render "books/book", book: book %>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No books found</h3>
        <p class="mt-1 text-sm text-gray-500">This series doesn't have any books yet.</p>
      </div>
    <% end %>
  </div>
</div>
