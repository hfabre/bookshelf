<div class="max-w-2xl mx-auto">
  <div class="mb-8">
    <%= link_to @serie, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      <%= t(".back", name: @serie.name) %>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= t(".heading") %></h1>

      <%= form_with model: @serie, local: true, class: "space-y-6" do |form| %>
        <% if @serie.errors.any? %>
          <div class="rounded-md bg-red-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  <%= t("common.error_header", count: @serie.errors.count) %>
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <% @serie.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div>
          <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :name,
              class: "form-input" %>
        </div>

        <div>
          <%= form.label :rating, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.select :rating,
              options_for_select([
                [t('.rating_options.none'), ''],
                [t('.rating_options.one_star'), 1],
                [t('.rating_options.two_stars'), 2],
                [t('.rating_options.three_stars'), 3],
                [t('.rating_options.four_stars'), 4],
                [t('.rating_options.five_stars'), 5]
              ], @serie.rating),
              {},
              class: "form-input" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <div class="flex items-center">
              <svg class="w-4 h-4 text-gray-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <%= t(".completion_label") %>
            </div>
            <span class="text-xs text-gray-500 ml-6"><%= t(".completion_hint") %></span>
          </label>
          <%= form.select :completion_state,
              options_for_select([
                [t('.completion_options.ongoing'), 'ongoing'],
                [t('.completion_options.completed'), 'completed'],
                [t('.completion_options.cancelled'), 'cancelled']
              ], @serie.completion_state),
              { include_blank: t('.completion_prompt') },
              class: "form-input" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            <div class="flex items-center">
              <svg class="w-4 h-4 text-gray-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              <%= t(".reading_label") %>
            </div>
            <span class="text-xs text-gray-500 ml-6"><%= t(".reading_hint") %></span>
          </label>
          <%= form.select :reading_state,
              options_for_select([
                [t('.reading_options.unread'), 'unread'],
                [t('.reading_options.reading'), 'reading'],
                [t('.reading_options.finished'), 'finished']
              ], @serie.reading_state),
              { include_blank: t('.reading_prompt') },
              class: "form-input" %>
        </div>

        <div class="flex items-center justify-end space-x-4">
          <%= link_to t("common.cancel"), @serie,
              class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>

          <%= form.submit class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
