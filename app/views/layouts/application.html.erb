<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t(".default_title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between border-b border-zinc-100 py-3 text-sm min-h-16">
        <div class="flex items-center gap-4">
          <a href="/">
            <%= image_tag("logo-no-background.svg", class: "max-w-56") %>
          </a>
        </div>
        <% if current_user %>
          <div class="flex items-center gap-4">
          <% unless browsing_other_library? %>
            <%= form_with url: upload_books_path, multipart: true, local: true,
                data: { controller: "upload", action: "change->upload#handleFiles" },
                class: "mr-4" do |form| %>
              <%= form.file_field :files, multiple: true, accept: ".epub",
                  class: "hidden", id: "epub-file-input",
                  data: { upload_target: "fileInput" } %>
              <%= form.button t(".upload_books"), type: "button",
                  class: "cursor-pointer inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
                  data: { action: "click->upload#openFileDialog" } %>
            <% end %>
          <% end %>

            <%= link_to t(".sign_out"), session_path, data: { turbo_method: :delete }, class: "inline-block rounded-sm border border-indigo-600 px-12 py-3 text-sm font-medium text-indigo-600 hover:bg-indigo-600 hover:text-white focus:ring-3 focus:outline-hidden" %>
          </div>
        <% end %>
      </div>
    </header>

    <div class="flex">
      <% if current_user %>
        <div class="flex h-screen flex-col justify-between border-e border-zinc-100 bg-white sticky top-0">
          <div class="px-4 py-6 min-w-64">
            <!-- Library Owner Section -->
            <div class="mb-6">
              <div class="px-4 py-2">
                <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide">
                  <%= browsing_other_library? ? t(".browsing_library") : t(".my_library") %>
                </h3>
                <p class="text-sm font-medium text-gray-900 mt-1">
                  <%= current_library_owner.display_name %>
                </p>
              </div>
            </div>

            <ul class="space-y-1">
              <li>
                <%= link_to current_series_path,
                    class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 3.75V16.5L12 14.25 7.5 16.5V3.75m9 0H18A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75h1.5m9 0h-9" />
                  </svg>
                  <%= t(".series") %>
                <% end %>
              </li>
              <li>
                <%= link_to current_authors_path,
                    class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                  </svg>
                  <%= t(".authors") %>
                <% end %>
              </li>
              <li>
                <%= link_to current_books_path,
                    class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                  </svg>
                  <%= t(".books") %>
                <% end %>
              </li>
            </ul>

            <!-- Me Section -->
            <div class="mt-8 pt-6 border-t border-gray-200">
              <div class="px-4 py-2 mb-4">
                <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide"><%= t(".me") %></h3>
              </div>

              <ul class="space-y-1">
                <% if browsing_other_library? %>
                  <li>
                    <%= link_to books_path, class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                      </svg>
                      <%= t(".back_to_my_library") %>
                    <% end %>
                  </li>
                <% end %>

                <li>
                  <%= link_to libraries_path, class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
                    </svg>
                    <%= t(".public_libraries") %>
                  <% end %>
                </li>

                <li>
                  <%= link_to edit_profile_path, class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                    <%= t(".edit_profile") %>
                  <% end %>
                </li>
              </ul>
            </div>

            <!-- Admin Section -->
            <% if current_user.admin? %>
              <div class="mt-8 pt-6 border-t border-gray-200">
                <div class="px-4 py-2 mb-4">
                  <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide"><%= t(".admin") %></h3>
                </div>

                <ul class="space-y-1">
                  <li>
                    <%= link_to users_path, class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                      </svg>
                      <%= t(".users") %>
                    <% end %>
                  </li>

                  <li>
                    <%= link_to failed_books_path, class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                      </svg>
                      <%= t(".failed_books") %>
                    <% end %>
                  </li>

                  <li>
                    <%= link_to mission_control_jobs_path, class: "items-center flex gap-2 rounded-lg px-4 py-2 text-sm font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-700" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                      </svg>
                      <%= t(".jobs") %>
                    <% end %>
                  </li>
                </ul>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="flex-1 flex flex-col min-w-0">
        <% if flash.any? %>
          <div class="container mx-auto px-5 mt-4">
            <% flash.each do |type, message| %>
              <% css_class = case type.to_s
                             when 'notice' then 'bg-green-50 border-green-200 text-green-800'
                             when 'alert' then 'bg-red-50 border-red-200 text-red-800'
                             else 'bg-blue-50 border-blue-200 text-blue-800'
                             end %>
              <div class="<%= css_class %> border rounded-md p-4 mb-4">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <% if type.to_s == 'notice' %>
                      <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                    <% elsif type.to_s == 'alert' %>
                      <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                      </svg>
                    <% else %>
                      <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                      </svg>
                    <% end %>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium">
                      <%= message %>
                    </p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>

        <main class="container mx-auto mt-6 px-5 flex flex-col">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
