<div class="max-w-4xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Public Libraries</h1>

  <% if @public_users.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @public_users.each do |user| %>
        <%= link_to library_path(user), class: "block" do %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition-shadow p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold text-gray-900">
                <%= user.email_address %>
              </h3>
              <% if user == current_user %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  Your Library
                </span>
              <% end %>
            </div>

            <div class="space-y-2 text-sm text-gray-600">
              <div class="flex items-center justify-between">
                <span>Books:</span>
                <span class="font-medium"><%= user.books.count %></span>
              </div>
              <div class="flex items-center justify-between">
                <span>Series:</span>
                <span class="font-medium"><%= user.series.count %></span>
              </div>
              <div class="flex items-center justify-between">
                <span>Authors:</span>
                <span class="font-medium"><%= user.authors.count %></span>
              </div>
            </div>

            <div class="mt-4 pt-4 border-t border-gray-100">
              <span class="text-xs text-gray-500">
                Library shared since <%= user.created_at.strftime("%B %Y") %>
              </span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No public libraries</h3>
      <p class="mt-1 text-sm text-gray-500">No users have made their libraries public yet.</p>
    </div>
  <% end %>
</div>
