<% content_for :title, t(".page_title", title: @book.title) %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t(".heading") %></h1>
    <p class="text-gray-600"><%= t(".subtitle") %></p>
  </div>

  <%= form_with model: @book, local: true, multipart: true,
      data: { controller: "book-form" },
      class: "space-y-6" do |form| %>

    <% if @book.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <h3 class="text-sm font-medium text-red-800"><%= t(".errors_heading") %></h3>
        <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
          <% @book.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Basic Book Information -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :title,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= form.label :date, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.date_field :date,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= form.label :language, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :language,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= form.label :publisher, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :publisher,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
    </div>

    <!-- Description -->
    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :description, rows: 4,
          class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Cover Upload -->
    <div>
      <%= form.label :cover, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="flex items-start space-x-4">
        <div class="flex-shrink-0">
          <% if @book.cover? %>
            <img src="<%= @book.cover_data_url %>" alt="Current cover" class="w-24 h-32 object-cover rounded-md border">
          <% else %>
            <div class="w-24 h-32 bg-gray-200 rounded-md border flex items-center justify-center">
              <span class="text-gray-400 text-xs"><%= t("common.no_cover") %></span>
            </div>
          <% end %>
        </div>
        <div class="flex-grow">
          <%= form.file_field :cover, accept: "image/*",
              data: { action: "change->book-form#handleCoverChange" },
              class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
          <p class="mt-1 text-sm text-gray-500"><%= t(".cover_hint") %></p>
        </div>
      </div>
    </div>

    <!-- Series Selection -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2"><%= t(".series_label") %></label>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="md:col-span-2 relative">
          <%= label_tag "book[serie_name]", t(".serie_name_label"), class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= text_field_tag "book[serie_name]", @book.serie&.name,
              placeholder: t(".serie_name_placeholder"),
              data: {
                book_form_target: "serieInput",
                action: "input->book-form#searchSeries focus->book-form#showSerieDropdown"
              },
              class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500",
              autocomplete: "off" %>

          <div data-book-form-target="serieDropdown"
               class="hidden absolute z-10 w-full bg-white shadow-lg max-h-60 rounded-md mt-1 overflow-auto border border-gray-200">
          </div>
        </div>

        <div>
          <%= form.label :serie_index, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.number_field :serie_index,
              class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>
    </div>

    <!-- Authors Selection -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2"><%= t(".authors_label") %></label>

      <!-- Selected Authors -->
      <div data-book-form-target="selectedAuthors" class="space-y-2 mb-4">
        <% @book.authors.each do |author| %>
          <div class="flex items-center justify-between bg-gray-50 px-3 py-2 rounded-md">
            <span><%= author.name %></span>
            <button type="button"
                    data-action="click->book-form#removeAuthor"
                    data-author-name="<%= author.name %>"
                    class="text-red-600 hover:text-red-700">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
            <input type="hidden" name="book[author_names][]" value="<%= author.name %>">
          </div>
        <% end %>
      </div>

      <!-- Author Search -->
      <div class="relative">
        <%= text_field_tag :author_query, "",
            placeholder: t(".author_search_placeholder"),
            data: {
              book_form_target: "authorInput",
              action: "input->book-form#searchAuthors focus->book-form#showAuthorDropdown keydown->book-form#handleAuthorKeydown"
            },
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500",
            autocomplete: "off" %>

        <div data-book-form-target="authorDropdown"
             class="hidden absolute z-10 w-full bg-white shadow-lg max-h-60 rounded-md mt-1 overflow-auto border border-gray-200">
        </div>
      </div>
      <p class="mt-1 text-sm text-gray-500"><%= t(".authors_hint") %></p>
    </div>

    <!-- Form Actions -->
    <div class="flex items-center justify-between pt-6 border-gray-200">
      <%= link_to t("common.cancel"), books_path,
          class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>

      <%= form.submit class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>
