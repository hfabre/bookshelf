<% authors.each do |author| %>
  <div class="flex items-center justify-between bg-gray-50 px-3 py-2 rounded-md">
    <span><%= author.name %></span>
    <%= button_to remove_author_book_path(@book),
        params: { author_id: author.id },
        method: :delete,
        remote: true,
        class: "text-red-600 hover:text-red-700 border-0 bg-transparent p-0" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    <% end %>
    <%= hidden_field_tag "author_ids[]", author.id %>
  </div>
<% end %>
