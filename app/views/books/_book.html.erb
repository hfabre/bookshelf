<div data-controller="modal" data-action="click->modal#open" data-modal-dialog-param="modal-<%= book.id %>" class="hover:cursor-pointer h-full flex flex-col">
    <div class="aspect-[2.8/4] w-full relative overflow-hidden flex-shrink-0">
        <%= book_cover(book, class: "object-cover w-full h-full absolute scale-110 blur") %>
        <%= book_cover(book, class: "object-contain w-full h-full absolute") %>
    </div>

    <div class="p-4 flex-1 flex flex-col justify-between min-h-[80px]">
        <h3 class="text-sm font-medium text-gray-900 line-clamp-2 leading-tight mb-2">
            <%= book.title %>
        </h3>

        <p class="text-xs text-gray-500 mt-auto">
            <% if book.serie %>
                <%= book.serie.name %><% if book.serie_index %> - #<%= book.serie_index %><% end %>
            <% else %>
                <%= book.author_names %>
            <% end %>
        </p>
    </div>
</div>
