<div class="bg-white sm:rounded-sm">
    <div class="px-4 py-5 sm:p-6">
        <%= form_with url: books_path, method: :get, local: true,
            data: {
            controller: "search",
            action: "turbo:submit-start->search#showLoading turbo:submit-end->search#hideLoading",
            turbo_frame: "books"
            },
            class: "space-y-4" do |form| %>

        <div>
            <%= form.text_field :q,
                value: params[:q],
                placeholder: "Search books by title or author...",
                class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6",
                data: {
                search_target: "input",
                action: "input->search#search"
                } %>
        </div>

        <div class="hidden" data-search-target="loading">
            <div class="text-sm text-gray-500">
                <span>Searching...</span>
            </div>
        </div>
        <% end %>
    </div>
</div>
