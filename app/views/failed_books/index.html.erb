<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900"><%= t(".heading") %></h1>
  </div>

  <% if @books.empty? %>
    <div class="bg-white shadow rounded-lg p-8 text-center text-gray-500">
      <%= t(".empty") %>
    </div>
  <% else %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= t(".book") %>
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= t(".owner") %>
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= t(".error") %>
            </th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= t(".failed_at") %>
            </th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
              <%= t(".actions") %>
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @books.each do |book| %>
            <tr>
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-gray-900"><%= book.title.presence || book.filename %></div>
                <div class="text-sm text-gray-500"><%= book.filename %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= book.user.email_address %>
              </td>
              <td class="px-6 py-4">
                <% if book.failure_message.present? %>
                  <span class="text-sm text-red-700"><%= truncate(book.failure_message, length: 160) %></span>
                <% else %>
                  <span class="text-sm text-gray-400">&mdash;</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= book.updated_at.strftime("%b %d, %Y %H:%M") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex items-center justify-end space-x-4">
                  <%= link_to t(".download"), download_failed_book_path(book), class: "text-indigo-600 hover:text-indigo-900" %>
                  <% if book.job_id.present? %>
                    <%= link_to t(".view_job"), mission_control_jobs.application_job_path("bookshelf", book.job_id), class: "text-indigo-600 hover:text-indigo-900" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
